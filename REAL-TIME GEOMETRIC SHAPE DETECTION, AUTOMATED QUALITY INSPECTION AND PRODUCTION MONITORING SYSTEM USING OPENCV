def draw_label_box(img, text, x, y, bg_color=(40, 40, 200), text_color=(255, 255, 255), center_x=False):
    font = cv2.FONT_HERSHEY_SIMPLEX
    font_scale = 0.55
    thickness = 2
    (text_w, text_h), _ = cv2.getTextSize(text, font, font_scale, thickness)
    if center_x:
        x = x - (text_w // 2)
    x = max(10, min(x, img.shape[1] - text_w - 20))
    y = max(text_h + 15, y)
    cv2.rectangle(img, (x, y - text_h - 10), (x + text_w + 10, y + 5), bg_color, -1)
    cv2.rectangle(img, (x, y - text_h - 10), (x + text_w + 10, y + 5), (255, 255, 255), 1)
    cv2.putText(img, text, (x + 5, y - 5), font, font_scale, text_color, thickness, cv2.LINE_AA)

def draw_multiline_label(img, lines, x, y, bg_color=(20, 20, 20), text_color=(255, 255, 255)):
    font = cv2.FONT_HERSHEY_SIMPLEX
    font_scale = 0.5
    thickness = 1
    line_gap = 6
    sizes = [cv2.getTextSize(line, font, font_scale, thickness)[0] for line in lines]
    max_w = max(w for w, h in sizes)
    line_h = max(h for w, h in sizes)
    total_h = (line_h + line_gap) * len(lines) + line_gap
    x = max(5, min(x, img.shape[1] - max_w - 20))
    y = max(0, min(y, img.shape[0] - total_h - 5))
    cv2.rectangle(img, (x, y), (x + max_w + 15, y + total_h), bg_color, -1)
    cv2.rectangle(img, (x, y), (x + max_w + 15, y + total_h), (255, 255, 255), 1)
    cur_y = y + line_gap + line_h
    for line in lines:
        cv2.putText(img, line, (x + 7, cur_y), font, font_scale, text_color, thickness, cv2.LINE_AA)
        cur_y += line_h + line_gap

