# ----------------------------------------------------
# CONTOUR DETECTION (with hierarchy, for hole counting)
# ----------------------------------------------------
def find_contours_with_hierarchy(gray):
    blurred = cv2.GaussianBlur(gray, (7, 7), 0)
    edges = cv2.Canny(blurred, CANNY_LOW, CANNY_HIGH)
    kernel = np.ones((3, 3), np.uint8)
    closed = cv2.morphologyEx(edges, cv2.MORPH_CLOSE, kernel, iterations=2)
    dilated = cv2.dilate(closed, kernel, iterations=2)
    contours, hierarchy = cv2.findContours(dilated.copy(), cv2.RETR_CCOMP, cv2.CHAIN_APPROX_SIMPLE)
    if hierarchy is None:
        hierarchy = np.empty((0, 1, 4), dtype=int)
    else:
        hierarchy = hierarchy[0]  # cv2 wraps it in an extra dim
    return contours, hierarchy

def count_holes(contours, hierarchy, parent_idx):
    """Counts child contours (holes) of a given parent index, ignoring
    tiny noise specks below MIN_HOLE_AREA."""
    count = 0
    for i, h in enumerate(hierarchy):
        if h[3] == parent_idx and cv2.contourArea(contours[i]) > MIN_HOLE_AREA:
            count += 1
    return count

# ----------------------------------------------------
# LIVE-CAMERA ANNOTATION (with object tracking)
# ----------------------------------------------------
class ObjectTracker:
    """Minimal nearest-centroid tracker: assigns a stable ID to each
    object across frames as long as it doesn't move more than
    max_distance pixels between frames."""
    def __init__(self, max_distance=60):
        self.next_id = 1
        self.objects = {}  # id -> (x, y)
        self.max_distance = max_distance

    def update(self, centroids):
        used_ids = set()
        new_objects = {}
        ids_for_input = []

        for c in centroids:
            best_id, best_dist = None, self.max_distance
            for oid, prev_c in self.objects.items():
                if oid in used_ids:
                    continue
                d = math.hypot(c[0] - prev_c[0], c[1] - prev_c[1])
                if d < best_dist:
                    best_dist = d
                    best_id = oid
            if best_id is None:
                best_id = self.next_id
                self.next_id += 1
            used_ids.add(best_id)
            new_objects[best_id] = c
            ids_for_input.append(best_id)

        self.objects = new_objects
        return ids_for_input

def annotate_shapes(img, target_shape="All", show_measurements=False, tracker=None):
    """Detects and labels every matching shape in img. If a tracker is
    given, also assigns/draws a stable Object ID per shape."""
    height, width = img.shape[:2]
    frame_area = height * width
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    contours, hierarchy = find_contours_with_hierarchy(gray)

    # Collect valid OUTER objects first (parent == -1 in RETR_CCOMP)
    objects = []
    for i, c in enumerate(contours):
        if hierarchy[i][3] != -1:
            continue  # this is a hole, not an outer object
        area = cv2.contourArea(c)
        if not (MIN_CONTOUR_AREA < area < (frame_area * MAX_CONTOUR_AREA_RATIO)):
            continue

        features = analyze_contour(c)
        shape_name = features["shape"]
        if target_shape != "All" and shape_name != target_shape:
            continue

        M = cv2.moments(c)
        cX = int(M["m10"] / M["m00"]) if M["m00"] != 0 else 0
        cY = int(M["m01"] / M["m00"]) if M["m00"] != 0 else 0

        objects.append({"contour": c, "shape": shape_name, "area": area, "cX": cX, "cY": cY})

    # Object tracking: assign stable IDs based on centroid proximity
    ids = None
    if tracker is not None and objects:
        ids = tracker.update([(o["cX"], o["cY"]) for o in objects])

    for idx, o in enumerate(objects):
        c = o["contour"]
        shape_name = o["shape"]
        percentage = (o["area"] / frame_area) * 100
        color_name = detect_color(img, c)

        cv2.drawContours(img, [c], -1, (0, 255, 0), 3, cv2.LINE_AA)

        label = f"{color_name} {shape_name} ({percentage:.1f}%)"
        draw_label_box(img, label, o["cX"], o["cY"],
                        bg_color=(40, 150, 40), text_color=(255, 255, 255), center_x=True)

        if ids is not None:
            draw_label_box(img, f"ID: {ids[idx]}", o["cX"], o["cY"] - 35,
                            bg_color=(150, 80, 0), text_color=(255, 255, 255), center_x=True)

        if show_measurements:
            dims = get_shape_dims(shape_name, c)
            draw_multiline_label(img, dims_to_lines(dims), o["cX"] - 60, o["cY"] + 25,
                                  bg_color=(60, 40, 40), text_color=(255, 255, 255))

    return img

# ----------------------------------------------------
# PRIMARY-OBJECT EXTRACTION (for QC reference/compare)
# ----------------------------------------------------
def find_primary_object(img):
    """Assumes ONE part per image: the largest valid outer contour.
    Returns a full profile dict (incl. holes, vertices, solidity), or
    None if nothing found.
    """
    height, width = img.shape[:2]
    frame_area = height * width
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    contours, hierarchy = find_contours_with_hierarchy(gray)

    candidates = []
    for i, c in enumerate(contours):
        if hierarchy[i][3] != -1:
            continue
        area = cv2.contourArea(c)
        if MIN_CONTOUR_AREA < area < (frame_area * MAX_CONTOUR_AREA_RATIO):
            candidates.append((i, c, area))

    if not candidates:
        return None

    idx, c, area = max(candidates, key=lambda t: t[2])
    features = analyze_contour(c)
    shape_name = features["shape"]
    color_name = detect_color(img, c)
    dims = get_shape_dims(shape_name, c)
    holes = count_holes(contours, hierarchy, idx)

    M = cv2.moments(c)
    cX = int(M["m10"] / M["m00"]) if M["m00"] != 0 else 0
    cY = int(M["m01"] / M["m00"]) if M["m00"] != 0 else 0

    return {
        "contour": c, "shape": shape_name, "color": color_name, "dims": dims,
        "vertices": features["vertices"], "solidity": features["solidity"],
        "holes": holes, "centroid": (cX, cY),
    }

# ----------------------------------------------------
# CONTOUR-LEVEL SHAPE DIFF (catches local/structural defects that
# vertex-count, solidity, and bounding-box checks miss)
# ----------------------------------------------------
def align_and_rasterize(contour, centroid, canvas_size=SHAPE_DIFF_CANVAS):
    """Shifts a contour so its centroid sits at the center of a square
    canvas, then rasterizes it into a filled binary mask. Aligning by
    centroid means two parts of the same size/shape overlap almost
    perfectly regardless of where they were positioned in their photo."""
    offset = canvas_size // 2
    shifted = contour.reshape(-1, 2).astype(np.int32) - np.array(centroid, dtype=np.int32) + offset
    mask = np.zeros((canvas_size, canvas_size), dtype=np.uint8)
    cv2.drawContours(mask, [shifted], -1, 255, -1)
    return mask

def compute_contour_shape_diff(ref_contour, ref_centroid, test_contour, test_centroid):
    """Aligns the reference and test contours by centroid and rasterizes
    both into filled masks, then measures how much of their combined
    outline area does NOT overlap. This is what actually catches things
    like a missing/extra notch, a chipped edge, or a deformed tab --
    differences that can leave vertex count, solidity, and width/height
    almost completely unchanged, and therefore invisible to the other
    checks below.

    Returns (diff_ratio, visual_bgr_image):
      diff_ratio       -- fraction (0-1) of the union area that differs
      visual_bgr_image -- an image with matching area in gray, area
                           present only in the reference in RED (i.e.
                           missing on the test part), and area present
                           only on the test part in YELLOW (i.e. extra
                           material on the test part)
    """
    ref_mask = align_and_rasterize(ref_contour, ref_centroid)
    test_mask = align_and_rasterize(test_contour, test_centroid)

    only_ref = cv2.bitwise_and(ref_mask, cv2.bitwise_not(test_mask))
    only_test = cv2.bitwise_and(test_mask, cv2.bitwise_not(ref_mask))
    overlap = cv2.bitwise_and(ref_mask, test_mask)

    union_area = cv2.countNonZero(cv2.bitwise_or(ref_mask, test_mask))
    diff_area = cv2.countNonZero(only_ref) + cv2.countNonZero(only_test)
    diff_ratio = (diff_area / union_area) if union_area > 0 else 0.0

    visual = np.zeros((ref_mask.shape[0], ref_mask.shape[1], 3), dtype=np.uint8)
    visual[overlap > 0] = (90, 90, 90)     # matches reference -> gray
    visual[only_ref > 0] = (0, 0, 255)     # missing on test part -> red
    visual[only_test > 0] = (0, 255, 255)  # extra on test part -> yellow

    # crop down to the union's bounding box (+ padding) so the popup
    # window isn't mostly empty canvas
    ys, xs = np.where(cv2.bitwise_or(ref_mask, test_mask) > 0)
    if len(xs) > 0:
        pad = 25
        x0, x1 = max(int(xs.min()) - pad, 0), min(int(xs.max()) + pad, visual.shape[1])
        y0, y1 = max(int(ys.min()) - pad, 0), min(int(ys.max()) + pad, visual.shape[0])
        visual = visual[y0:y1, x0:x1]

    return diff_ratio, visual

# ----------------------------------------------------
# QC COMPARISON (now with defect detection)
# ----------------------------------------------------
def compare_to_reference(reference, test):
    """Compares a test-part profile against the reference profile.
    Returns (passed, reasons, diff_visual).

    Checks performed:
      1. Shape match (wrong shape entirely)
      2. Hole count match (extra/missing holes)
      3. Vertex count match (broken/missing corners)
      4. Solidity drop (deformed/broken shape outline)
      5. Contour outline diff (local/structural defects -- notches,
         chips, added or missing material -- via centroid-aligned mask
         overlap; catches changes that 1-4 and the dimension check
         below can miss entirely)
      6. Dimension match within SIZE_TOLERANCE_PERCENT (real or pixel units)
    """
    reasons = []
    diff_visual = None

    if test["shape"] != reference["shape"]:
        reasons.append(f"Shape mismatch: expected {reference['shape']}, got {test['shape']}")
        return False, reasons

    if test["holes"] != reference["holes"]:
        if test["holes"] > reference["holes"]:
            reasons.append(f"Extra hole(s) detected: expected {reference['holes']}, found {test['holes']}")
        else:
            reasons.append(f"Missing hole(s): expected {reference['holes']}, found {test['holes']}")

    vertex_diff = abs(test["vertices"] - reference["vertices"])
    if vertex_diff > VERTEX_DIFF_TOLERANCE:
        reasons.append(
            f"Possible broken/missing corner: expected ~{reference['vertices']} corners, "
            f"got {test['vertices']}"
        )

    solidity_drop = reference["solidity"] - test["solidity"]
    if solidity_drop > SOLIDITY_DROP_TOLERANCE:
        reasons.append(
            f"Shape appears broken/deformed (solidity dropped {solidity_drop:.2f})"
        )

    # Contour-level outline check -- catches local defects (notches,
    # chipped edges, extra tabs, etc.) that vertex count, solidity, and
    # aggregate dimensions can all miss when the overall size/shape
    # "on average" still looks right.
    diff_ratio, diff_visual = compute_contour_shape_diff(
        reference["contour"], reference["centroid"],
        test["contour"], test["centroid"],
    )
    print(f"  contour outline diff: {diff_ratio * 100:.2f}%")
    if diff_ratio > SHAPE_DIFF_TOLERANCE:
        reasons.append(
            f"Contour outline differs from reference by {diff_ratio * 100:.1f}% "
            f"(possible notch, chip, or added/missing material -- see contour diff view)"
        )

    ref_dims = reference["dims"]
    test_dims = test["dims"]
    shared_keys = [k for k in ref_dims if k in test_dims and k != "perimeter"]
    for key in shared_keys:
        ref_val = ref_dims[key]
        test_val = test_dims[key]
        if ref_val == 0:
            continue
        pct_diff = abs(test_val - ref_val) / ref_val * 100
        print(f"  {key}: ref={ref_val:.1f}px test={test_val:.1f}px diff={pct_diff:.3f}%")
        if pct_diff > SIZE_TOLERANCE_PERCENT:
            unit = UNIT_NAME if PIXELS_PER_UNIT else "px"
            rv = ref_val / PIXELS_PER_UNIT if PIXELS_PER_UNIT else ref_val
            tv = test_val / PIXELS_PER_UNIT if PIXELS_PER_UNIT else test_val
            reasons.append(
                f"{key.capitalize()} off by {pct_diff:.1f}% "
                f"(expected {rv:.2f}{unit}, got {tv:.2f}{unit})"
            )

    passed = len(reasons) == 0
    return passed, reasons, diff_visual

# ----------------------------------------------------
# CAMERA HELPERS
# ----------------------------------------------------
def open_camera(max_index=3):
    system = platform.system()
    if system == "Windows":
        backend = cv2.CAP_DSHOW
    elif system == "Linux":
        backend = cv2.CAP_V4L2
    else:
        backend = cv2.CAP_ANY

    for i in range(max_index):
        cap = cv2.VideoCapture(i, backend)
        if not cap.isOpened():
            cap.release()
            cap = cv2.VideoCapture(i)
        if cap.isOpened():
            ret, frame = cap.read()
            if ret and np.any(frame):
                print(f"Successfully connected to Camera {i}!")
                return cap
        cap.release()
    return None

# ----------------------------------------------------
# IMAGE FILE HELPERS
# ----------------------------------------------------
def pick_image_file():
    root = tk.Tk()
    root.withdraw()
    root.attributes("-topmost", True)
    path = filedialog.askopenfilename(
        title="Select an image",
        filetypes=[("Image files", "*.jpg *.jpeg *.png *.bmp *.webp"), ("All files", "*.*")]
    )
    root.destroy()
    return path or None

def pick_image_files_multi():
    root = tk.Tk()
    root.withdraw()
    root.attributes("-topmost", True)
    paths = filedialog.askopenfilenames(
        title="Select one or more produced-part images",
        filetypes=[("Image files", "*.jpg *.jpeg *.png *.bmp *.webp"), ("All files", "*.*")]
    )
    root.destroy()
    return list(paths)

def resize_to_fit(img, max_dim=MAX_UPLOADED_IMAGE_DIM):
    h, w = img.shape[:2]
    scale = max_dim / float(max(h, w))
    if scale < 1.0:
        img = cv2.resize(img, (int(w * scale), int(h * scale)), interpolation=cv2.INTER_AREA)
    return img

# ----------------------------------------------------
# QC WORKFLOW MODES
# ----------------------------------------------------
def run_set_reference_mode():
    """Upload the ORIGINAL/correct part image, store its full profile as
    the reference, and (optionally) calibrate pixel-to-cm conversion.
    """
    path = pick_image_file()
    if not path:
        print("No reference image selected.")
        return None

    img = cv2.imread(path)
    if img is None:
        print(f"ERROR: Could not read image at {path}")
        return None

    img = resize_to_fit(img)
    profile = find_primary_object(img)

    if profile is None:
        print("Could not detect any object in the reference image.")
        cv2.imshow("Reference - NO OBJECT DETECTED", img)
        cv2.waitKey(0)
        cv2.destroyWindow("Reference - NO OBJECT DETECTED")
        return None

    calibrate_from_profile(profile)

    display = img.copy()
    cv2.drawContours(display, [profile["contour"]], -1, (0, 255, 255), 3, cv2.LINE_AA)
    label = f"REFERENCE: {profile['color']} {profile['shape']} | Holes: {profile['holes']}"
    draw_label_box(display, label, profile["centroid"][0], profile["centroid"][1],
                    bg_color=(0, 150, 200), text_color=(0, 0, 0), center_x=True)
    draw_multiline_label(display, dims_to_lines(profile["dims"]),
                          profile["centroid"][0] - 60, profile["centroid"][1] + 25,
                          bg_color=(60, 40, 40))
    cv2.putText(display, "Reference set. Press any key to continue...", (15, display.shape[0] - 15),
                cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 255), 1, cv2.LINE_AA)

    cv2.imshow("Reference Part", display)
    cv2.waitKey(0)
    cv2.destroyWindow("Reference Part")

    print(f"Reference set: {profile['color']} {profile['shape']} | holes={profile['holes']} | {dims_to_lines(profile['dims'])}")
    return profile

def run_compare_mode(reference):
    """Upload one or more PRODUCED part images, compare each against the
    reference (shape, holes, corners, solidity, size), show a PASS/FAIL
    verdict, log it to CSV, save a screenshot if it failed, and update
    the production dashboard.
    """
    if reference is None:
        print("No reference set yet. Press SHIFT+R first.")
        return

    paths = pick_image_files_multi()
    if not paths:
        print("No images selected for comparison.")
        return

    for path in paths:
        img = cv2.imread(path)
        if img is None:
            print(f"ERROR: Could not read image at {path}")
            continue

        img = resize_to_fit(img)
        test_profile = find_primary_object(img)
        display = img.copy()

        if test_profile is None:
            passed = False
            reasons = ["No object detected in image"]
            draw_verdict_banner(display, passed, reasons)
            record_result(passed)
            log_csv_row("Unknown", "Unknown", "FAIL", reasons, path)
            saved_path = save_defect_screenshot(display)
            print(f"Defect screenshot saved: {saved_path}")
        else:
            print(f"\nComparing: {path}")
            passed, reasons, diff_visual = compare_to_reference(reference, test_profile)

            # AI-style confidence readout
            top_shapes = shape_confidence_scores(test_profile["vertices"], test_profile["solidity"])
            confidence_lines = [f"{name}: {pct:.0f}%" for name, pct in top_shapes]

            cv2.drawContours(display, [test_profile["contour"]], -1,
                              (0, 255, 0) if passed else (0, 0, 255), 3, cv2.LINE_AA)
            draw_verdict_banner(display, passed, reasons)
            draw_multiline_label(display, dims_to_lines(test_profile["dims"]),
                                  test_profile["centroid"][0] - 60, test_profile["centroid"][1] + 25,
                                  bg_color=(60, 40, 40))
            draw_multiline_label(display, confidence_lines,
                                  test_profile["centroid"][0] - 60, test_profile["centroid"][1] + 110,
                                  bg_color=(80, 20, 80))

            record_result(passed)
            log_csv_row(test_profile["shape"], test_profile["color"],
                        "PASS" if passed else "FAIL", reasons, path)

            if not passed:
                saved_path = save_defect_screenshot(display)
                print(f"Defect screenshot saved: {saved_path}")
                if diff_visual is not None:
                    diff_path = os.path.join(DEFECT_DIR, f"defect_{production_stats['fail']}_diff.png")
                    cv2.imwrite(diff_path, diff_visual)
                    print(f"Contour diff image saved: {diff_path}")
                    cv2.imshow("Contour Diff (red=missing, yellow=extra)", diff_visual)

        draw_dashboard(display)
        cv2.putText(display, "Press any key for next image...", (15, display.shape[0] - 15),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 255), 1, cv2.LINE_AA)
        cv2.imshow("QC Result", display)
        cv2.waitKey(0)
        cv2.destroyWindow("QC Result")
        try:
            cv2.destroyWindow("Contour Diff (red=missing, yellow=extra)")
        except cv2.error:
            pass

    print("\n--- PRODUCTION DASHBOARD ---")
    print(f"Total Parts: {production_stats['total']}")
    print(f"PASS: {production_stats['pass']}")
    print(f"FAIL: {production_stats['fail']}")
    print(f"Efficiency: {efficiency_percent():.1f}%")
    print(f"Full report: {os.path.abspath(CSV_PATH)}\n")

# ----------------------------------------------------
# MAIN APPLICATION
# ----------------------------------------------------
def main():
    print("Initializing camera... This might take a few seconds.")
    init_csv_report()

    face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')

    cap = open_camera()
    if cap is None:
        print("\nERROR: Could not find a working camera.")
        return

    print("Press 'q' to quit.")
    print("Press SHIFT+R to upload the REFERENCE (original/correct) part image.")
    print("Press SHIFT+C to upload and COMPARE produced-part image(s) against the reference.")
    target_shape = "All"
    reference_profile = None
    tracker = ObjectTracker()

    consecutive_failed_reads = 0
    MAX_FAILED_READS = 10

    while True:
        ret, frame = cap.read()
        if not ret:
            consecutive_failed_reads += 1
            if consecutive_failed_reads >= MAX_FAILED_READS:
                print("\nERROR: Camera stopped responding.")
                break
            continue
        consecutive_failed_reads = 0

        height, width, _ = frame.shape
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

        if target_shape in ("All", "Human"):
            faces = face_cascade.detectMultiScale(
                gray, scaleFactor=FACE_SCALE_FACTOR,
                minNeighbors=FACE_MIN_NEIGHBORS, minSize=FACE_MIN_SIZE,
            )
            for (x, y, w, h) in faces:
                draw_target_box(frame, x, y, w, h, color=(0, 255, 255))
                draw_label_box(frame, "HUMAN DETECTED", x, y - 5,
                                bg_color=(0, 200, 200), text_color=(0, 0, 0))

        if target_shape != "Human":
            annotate_shapes(frame, target_shape=target_shape, show_measurements=False, tracker=tracker)

        overlay = frame.copy()
        cv2.rectangle(overlay, (0, 0), (width, 100), (20, 20, 20), -1)
        cv2.addWeighted(overlay, 0.7, frame, 0.3, 0, frame)

        cv2.putText(frame, "TARGET MODE:", (15, 35), cv2.FONT_HERSHEY_SIMPLEX, 0.65, (200, 200, 200), 1, cv2.LINE_AA)
        cv2.putText(frame, target_shape.upper(), (175, 35), cv2.FONT_HERSHEY_SIMPLEX, 0.7, (0, 255, 255), 2, cv2.LINE_AA)

        ref_status = "SET" if reference_profile else "NOT SET"
        ref_color = (0, 255, 0) if reference_profile else (0, 0, 255)
        cv2.putText(frame, f"QC REFERENCE: {ref_status}", (width - 260, 35),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.55, ref_color, 2, cv2.LINE_AA)

        inst1 = "KEYS: [A]ll | [T]riangle | [S]quare | [Rect]angle | [P]entagon | [Circ]le"
        inst2 = "      [D]iamond | [H]eart | [*]Star | [U]Human | SHIFT+[R]=Set Ref | SHIFT+[C]=Compare | [Q]uit"
        cv2.putText(frame, inst1, (15, 65), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (220, 220, 220), 1, cv2.LINE_AA)
        cv2.putText(frame, inst2, (15, 85), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (220, 220, 220), 1, cv2.LINE_AA)

        draw_dashboard(frame)

        cv2.imshow("Shape Detection Pro - QC Mode", frame)

        key = cv2.waitKey(1) & 0xFF
        if key == ord('q'):
            break
        elif key == ord('R'):
            reference_profile = run_set_reference_mode()
            continue
        elif key == ord('C'):
            run_compare_mode(reference_profile)
            continue

        key_char = chr(key) if 0 <= key < 256 else ''
        if key_char in KEY_TO_SHAPE:
            target_shape = KEY_TO_SHAPE[key_char]

    cap.release()
    cv2.destroyAllWindows()
    print("\n--- FINAL SESSION SUMMARY ---")
    print(f"Total Parts: {production_stats['total']}")
    print(f"PASS: {production_stats['pass']}")
    print(f"FAIL: {production_stats['fail']}")
    print(f"Efficiency: {efficiency_percent():.1f}%")
    print(f"CSV report: {os.path.abspath(CSV_PATH)}")
    print(f"Defect screenshots: {os.path.abspath(DEFECT_DIR)}")

if __name__ == "__main__":
    main()
