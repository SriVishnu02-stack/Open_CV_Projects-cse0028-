# ----------------------------------------------------
# COLOR DETECTION
# ----------------------------------------------------
def detect_color(frame, c):
    mask = np.zeros(frame.shape[:2], dtype="uint8")
    cv2.drawContours(mask, [c], -1, 255, -1)
    hsv_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
    mean_hsv = cv2.mean(hsv_frame, mask=mask)[:3]
    h, s, v = mean_hsv
    if s < 40 and v > 180:
        return "White"
    elif v < 50:
        return "Black"
    elif s < 50:
        return "Gray"
    if h < 10 or h > 165:
        return "Red"
    elif h < 22:
        return "Orange"
    elif h < 35:
        return "Yellow"
    elif h < 85:
        return "Green"
    elif h < 135:
        return "Blue"
    else:
        return "Purple"

# ----------------------------------------------------
# SHAPE ANALYSIS (shape, vertices, solidity all in one pass)
# ----------------------------------------------------
def analyze_contour(c):
    """Returns {'shape', 'vertices', 'solidity'} for a contour."""
    peri = cv2.arcLength(c, True)
    approx = cv2.approxPolyDP(c, APPROX_EPSILON_RATIO * peri, True)
    area = cv2.contourArea(c)
    (x, y, w, h) = cv2.boundingRect(approx)
    hull = cv2.convexHull(c)
    hull_area = cv2.contourArea(hull)
    solidity = area / float(hull_area) if hull_area > 0 else 0
    n = len(approx)

    shape = "Unknown"
    if n == 3:
        shape = "Triangle"
    elif n == 4:
        rect = cv2.minAreaRect(c)
        angle = rect[2]
        tilt = angle % 90
        tilt = min(tilt, 90 - tilt)
        if tilt > 20:
            shape = "Diamond"
        else:
            ar = w / float(h) if h != 0 else 0
            shape = "Square" if SQUARE_ASPECT_LOW <= ar <= SQUARE_ASPECT_HIGH else "Rectangle"
    elif n == 5 and solidity > 0.85:
        shape = "Pentagon"
    elif n == 6 and solidity > 0.85:
        shape = "Hexagon"
    else:
        if solidity > SOLIDITY_CIRCLE:
            shape = "Circle"
        elif SOLIDITY_HEART_LOW < solidity <= SOLIDITY_CIRCLE:
            shape = "Heart"
        else:
            shape = "Star"

    return {"shape": shape, "vertices": n, "solidity": solidity}

def detect_shape(c):
    return analyze_contour(c)["shape"]

# ----------------------------------------------------
# AI-STYLE SHAPE CONFIDENCE (heuristic, not a trained model)
# ----------------------------------------------------
SHAPE_TEMPLATES = {
    "Triangle": (3, 0.99), "Square": (4, 0.99), "Rectangle": (4, 0.92),
    "Diamond": (4, 0.90), "Pentagon": (5, 0.92), "Hexagon": (6, 0.92),
    "Circle": (10, 0.97), "Heart": (8, 0.80), "Star": (10, 0.55),
}

def shape_confidence_scores(vertices, solidity, top_n=3):
    """Heuristic 'AI-style' confidence: scores each known shape template
    by how close this contour's vertex count and solidity are to that
    template, then normalizes into percentages. This is NOT a trained
    classifier -- it's a geometric similarity score dressed up as one.
    """
    scores = {}
    for name, (tv, tsol) in SHAPE_TEMPLATES.items():
        vertex_term = math.exp(-((vertices - tv) ** 2) / 8.0)
        solidity_term = math.exp(-((solidity - tsol) ** 2) / 0.02)
        scores[name] = vertex_term * solidity_term

    total = sum(scores.values()) or 1e-9
    pct = {k: (v / total) * 100 for k, v in scores.items()}
    ranked = sorted(pct.items(), key=lambda kv: kv[1], reverse=True)
    return ranked[:top_n]

# ----------------------------------------------------
# REAL-WORLD MEASUREMENT (pixel -> cm conversion)
# ----------------------------------------------------
def get_shape_dims(shape_name, c):
    """Raw pixel dimensions for a contour."""
    area = cv2.contourArea(c)
    perimeter = cv2.arcLength(c, True)
    dims = {"area": area, "perimeter": perimeter}

    if shape_name == "Circle":
        radius = np.sqrt(area / np.pi)
        dims["radius"] = radius
        dims["diameter"] = radius * 2
    elif shape_name == "Square":
        dims["side"] = perimeter / 4.0
    elif shape_name in ("Rectangle", "Diamond"):
        rect = cv2.minAreaRect(c)
        (rw, rh) = rect[1]
        dims["width"] = max(rw, rh)
        dims["height"] = min(rw, rh)
    elif shape_name == "Triangle":
        dims["avg_side"] = perimeter / 3.0
    elif shape_name == "Pentagon":
        dims["avg_side"] = perimeter / 5.0
    elif shape_name == "Hexagon":
        dims["avg_side"] = perimeter / 6.0

    return dims

def dims_to_lines(dims):
    """Converts a pixel-dims dict into display-ready strings, in real
    units (cm) if calibrated, otherwise pixels."""
    label_map = {
        "radius": "Radius", "diameter": "Diameter", "side": "Side",
        "width": "Width", "height": "Height", "avg_side": "Avg side",
        "perimeter": "Perimeter", "area": "Area",
    }
    calibrated = PIXELS_PER_UNIT is not None
    lines = []
    for key in ("radius", "diameter", "side", "width", "height", "avg_side"):
        if key in dims:
            if calibrated:
                val = dims[key] / PIXELS_PER_UNIT
                lines.append(f"{label_map[key]}: {val:.2f}{UNIT_NAME}")
            else:
                lines.append(f"{label_map[key]}: {dims[key]:.1f}px")

    if calibrated:
        lines.append(f"Perimeter: {dims['perimeter'] / PIXELS_PER_UNIT:.2f}{UNIT_NAME}")
        lines.append(f"Area: {dims['area'] / (PIXELS_PER_UNIT ** 2):.2f}{UNIT_NAME}^2")
    else:
        lines.append(f"Perimeter: {dims['perimeter']:.1f}px")
        lines.append(f"Area: {dims['area']:.0f}px^2")
    return lines

