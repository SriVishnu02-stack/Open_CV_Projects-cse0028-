MIN_CONTOUR_AREA = 1500
MAX_CONTOUR_AREA_RATIO = 0.95
MIN_HOLE_AREA = 80                  # ignore tiny noise specks when counting holes

APPROX_EPSILON_RATIO = 0.04

SQUARE_ASPECT_LOW = 0.95
SQUARE_ASPECT_HIGH = 1.05

SOLIDITY_CIRCLE = 0.92
SOLIDITY_HEART_LOW = 0.70

CANNY_LOW = 30
CANNY_HIGH = 100

FACE_SCALE_FACTOR = 1.1
FACE_MIN_NEIGHBORS = 12
FACE_MIN_SIZE = (100, 100)

MAX_UPLOADED_IMAGE_DIM = 1000

# QC tolerances
SIZE_TOLERANCE_PERCENT = 2.0
VERTEX_DIFF_TOLERANCE = 1            # allowed difference in corner count
SOLIDITY_DROP_TOLERANCE = 0.08       # allowed drop in solidity before "deformed"
SHAPE_DIFF_TOLERANCE = 0.015         # max allowed non-overlapping outline area (after
                                      # centroid-aligning ref & test contours) before flagging
                                      # a structural/local shape defect (notch, chip, extra tab...).
                                      # Tuned so normal camera/segmentation jitter (~0.5-1%) passes
                                      # but small real notches/chips (~1.5%+) get caught. If you get
                                      # false positives from lighting/angle noise, raise slightly;
                                      # if small defects are slipping through, lower it.
SHAPE_DIFF_CANVAS = 700              # size of the square canvas used to rasterize/compare contours

# Real-world unit calibration (set when reference is captured)
PIXELS_PER_UNIT = None               # px per cm, once calibrated
UNIT_NAME = "cm"

