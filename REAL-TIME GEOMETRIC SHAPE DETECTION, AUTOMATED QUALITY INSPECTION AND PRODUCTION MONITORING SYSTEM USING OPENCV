production_stats = {"total": 0, "pass": 0, "fail": 0}

def record_result(passed):
    production_stats["total"] += 1
    production_stats["pass" if passed else "fail"] += 1

def efficiency_percent():
    if production_stats["total"] == 0:
        return 100.0
    return (production_stats["pass"] / production_stats["total"]) * 100.0

# ----------------------------------------------------
# CSV REPORT LOGGING
# ----------------------------------------------------
def init_csv_report():
    if not os.path.exists(CSV_PATH):
        with open(CSV_PATH, "w", newline="") as f:
            writer = csv.writer(f)
            writer.writerow(["Time", "Shape", "Color", "Result", "Reasons", "ImagePath"])

def log_csv_row(shape, color, result, reasons, image_path=""):
    init_csv_report()
    with open(CSV_PATH, "a", newline="") as f:
        writer = csv.writer(f)
        writer.writerow([
            datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            shape, color, result, "; ".join(reasons), image_path
        ])

def save_defect_screenshot(img):
    os.makedirs(DEFECT_DIR, exist_ok=True)
    idx = production_stats["fail"]
    path = os.path.join(DEFECT_DIR, f"defect_{idx}.png")
    cv2.imwrite(path, img)
    return path

