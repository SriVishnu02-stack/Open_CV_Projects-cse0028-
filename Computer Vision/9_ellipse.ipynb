   "source": [
    "# Program to draw an ellipse on an image\n",
    "\n",
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "img=cv2.imread(\"mon.jpg\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "\n",
    "cv2.ellipse(img,(200,300),(150,75),0,0,360,(255,0,0),10)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.title(\"Ellipse\")\n",
    "plt.show()"
   ]
