    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "img=cv2.imread(\"ntr.png\")\n",
    "img=cv2.cvtColor(img,cv2.COLOR_BGR2RGB)\n",
    "cv2.putText(img,\"Dragon\",(200,200),\n",
    "cv2.FONT_HERSHEY_SIMPLEX,\n",
    "1,(255,0,0),2)\n",
    "plt.imshow(img)\n",
    "plt.show()"
   ]
